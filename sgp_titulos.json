    $("#cadastronegativo").off("click").on("click", function() { 
		let titulosEmDia = 0;
		let contratos = new Set();
		let data = [];          
          $(".titulosA:input[name=titulos\\[\\]]:checked").each(function(){
        	data.push($(this).val());
			
			var diasVencido = $(this).closest("tr").data("dias");
			if(diasVencido < 0){
				titulosEmDia ++
			}
			contrato = $(this).closest("tr").data("contrato").toString();
			contratos.add(contrato);
      	});

		if (data.length === 0) { 
			alert("Nenhum título selecionado.");
			return false;
		}

		if (contratos.size > 1) {
			alert("Selecione apenas títulos de mesmo contratos.");
			return false;
		}

		if (contratos.has("")) {
			alert("Selecione apenas títulos com contratos vinculados.");
			return false;
		}

		if(titulosEmDia > 0){
			alert("Existem títulos selecionados que estão em dia.\nA negativação só poderá ser realizada com títulos em atraso.");
			return false;
		}
		$.ajax({
			url: '/admin/financeiro/titulo/aviso/ajax/',
			type: 'GET', 
			data: {
				titulos: data.join(',')
			},
			success: function(response) {
				const titulos_negativados = response.titulos_negativados;
				const titulos_n_negativados = response.titulos_n_negativados;
				const aviso = response.avisos;

				if (titulos_negativados.length > 0) {
					const mensagem = aviso + "\nDeseja prosseguir mesmo assim?";
					if (!confirm(mensagem)) {
						return;
					}
				}
				
				$('#formtitulolote')
					.attr('action', '/admin/cliente/2048/cadastronegativo/add')
					.attr('target', '_blank')
					.submit();
			},
			error: function(error) {
				console.log(error);
				$('#formtitulolote')
					.attr('action', '/admin/cliente/2048/cadastronegativo/add')
					.attr('target', '_blank')
					.submit();
			}
		});      
     
    });

		$("#sincronizartitulo").click(function() {       
		  var data = new Array();	        
      $(".titulosA:input[name=titulos\\[\\]]:checked").each(function(){
				data.push($(this).val());
			});
      
      if (data.length == 0) { 
        Swal.fire({
          title: "Nenhum título selecionado.",
          icon: "error"
        });
        return false;
      }

      Swal.fire({
        title: "Deseja sincronizar os Títulos selecionados com a Gateway ?",
        icon: "info",
        showCancelButton: true,
        confirmButtonText: "Sincronizar",
        cancelButtonText: "Cancelar",
        allowOutsideClick: false,
        animation: false,
      }).then((result) => {
        if (result.isConfirmed) {
          setTimeout(function(){
            Swal.fire({
              icon: "warning",
              title: "Processando ...",
              text: "Atenção, os títulos estão sendo sincronizados. Aguarde até a finalização antes de realizar algum outro processo.",
              footer: "Esta página será atualizada automaticamente quando o processo for finalizado.",
              showCancelButton: false,
              showConfirmButton: false,
              allowOutsideClick: false,
            });
          }, 100);

          $('#formtitulolote').attr('action','/admin/financeiro/titulo/gateway/cliente/2048/sync/list/');
          $('#formtitulolote').attr('target','_self');
          $('#formtitulolote').submit();
        }
      });
		});

