	   function tituloAvisoConfirm(url_action, url_confirm) {
			$.ajax({
				url: url_confirm,
				global: false,
				success: function(data) {
					if (data.avisos.length > 0) {
						var avisos = "";
					
						$.each(data.avisos, function(index, value) {
							avisos += value + "\n";
						});

						avisos += "Deseja prosseguir?";

						if (confirm(avisos)) {window.location=url_action;}
					} else {
						window.location=url_action;
					}
				},
				error: function(xhr) {window.location=url_action;}
			});
		}
